    },
    "ok": {
      "id": "ok",
      "type": "ACTION_TOAST",
      "params": { "message": "截屏成功" }
    },
    "fail": {
      "id": "fail",
      "type": "ACTION_TOAST",
      "params": { "message": "截屏失败，检查 Shizuku" }
    }
  }
}
