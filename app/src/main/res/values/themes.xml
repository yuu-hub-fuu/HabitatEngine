<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Habitat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#0D9488</item>
        <item name="colorPrimaryVariant">#0F766E</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#0891B2</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.Habitat.Transparent" parent="Theme.Habitat">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

</resources>
